    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// --- 1. ID抽出ロジック ---\nconst extractId = (insightId) => {\n  // Insights APIのIDは \"12345/insights/...\" のような形式になることがあるため数値だけ抽出\n  const m = String(insightId || '').match(/^\\d+/);\n  return m ? m[0] : '';\n};\n\n// --- 2. データソースの整理 ---\n// Postデータ（n8nの右側入力：投稿の基本情報）\nconst post = $input.item.json;\n\n// Insightsデータ（n8nの左側入力：APIレスポンス）\n// 公式Docsによると構造は { data: [ { name: \"views\", values: [...] }, ... ] }\nconst insightsData = $json.data || [];\n\n// IDの照合\nconst insightIdRaw = $json.id ?? $json.data?.[0]?.id;\nconst postId = insightIdRaw ? extractId(insightIdRaw) : post.id;\n\n// --- 3. 指標取得用関数 (公式仕様準拠) ---\n// nameには \"views\", \"likes\", \"replies\", \"reposts\", \"quotes\" が入ります\nconst getMetricValue = (metricName) => {\n  // data配列から name が一致するオブジェクトを探す\n  const metricObj = insightsData.find(item => item.name === metricName);\n  \n  // 見つかったら values[0].value を返す。なければ 0\n  // ※期間指定(period)等がある場合も values 配列の先頭に入ることが一般的です\n  return metricObj?.values?.[0]?.value ?? 0;\n};\n\n// --- 4. 結果の出力 ---\nreturn {\n  json: {\n    id: postId,\n    \n    // テキスト・日付・リンクは元の投稿データから取得\n    caption: post.caption || post.text, \n    permalink: post.permalink,\n    timestamp: post.timestamp,\n    \n    // 数値データは全て Insights API のレスポンスから取得\n    // 公式ドキュメントの \"Available Metrics\" に基づきマッピング\n    views: getMetricValue('views'),\n    likes: getMetricValue('likes'),\n    replies: getMetricValue('replies'), // ここでコメント数が取れるはずです\n    reposts: getMetricValue('reposts'),\n    quotes: getMetricValue('quotes'),\n    \n    // デバッグ用: もしAPI設定漏れでデータが来ていないか確認するため\n    _raw_insights_names: insightsData.map(d => d.name).join(', ')\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        64
      ],
      "id": "b4e521c6-b94b-4ca2-b435-5eef7c9a2370",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// もし \"items\" が全投稿配列なら:\nconst posts = items.map(item => item.json);\n\n/**\n * 総合エンゲージメント率 (いいね + コメント) / 閲覧数 で降順ソート\n * これにより、単純な閲覧数稼ぎではなく「熱狂を生んだ投稿」が1位になります\n */\nposts.sort((a, b) => {\n  // 安全に値を取得 (repliesがない場合は0扱い)\n  const repliesA = a.replies || 0;\n  const repliesB = b.replies || 0;\n\n  // Aの総合エンゲージメント率計算\n  const rateA = a.views > 0 ? ((a.likes + repliesA) / a.views) : 0;\n  \n  // Bの総合エンゲージメント率計算\n  const rateB = b.views > 0 ? ((b.likes + repliesB) / b.views) : 0;\n  \n  // 降順 (大きい順)\n  return rateB - rateA;\n});\n\n// rankと計算したrateを付与して返す\n// ※すでにソート済みなので、ここでの i+1 が「総合エンゲージメントランク」になります\nreturn posts.map((p, i) => {\n  // 安全対策: repliesがnull/undefinedなら0にする\n  const replyCount = p.replies || 0; \n\n  // 1. いいね率の計算\n  const likeRateVal = p.views > 0 ? (p.likes / p.views) * 100 : 0;\n  \n  // 2. コメント率の計算\n  const commentRateVal = p.views > 0 ? (replyCount / p.views) * 100 : 0;\n\n  // 3. 総合エンゲージメント率: (いいね + コメント) / 閲覧数\n  const totalEngagementVal = p.views > 0 ? ((p.likes + replyCount) / p.views) * 100 : 0;\n\n  return {\n    json: {\n      ...p,\n      // 既存のいいね率\n      engagement_rate: parseFloat(likeRateVal.toFixed(2)) + '%', \n      \n      // コメント率\n      comment_rate: parseFloat(commentRateVal.toFixed(2)) + '%', \n      \n      // 総合エンゲージメント率 (これがソート基準です)\n      total_engagement_rate: parseFloat(totalEngagementVal.toFixed(2)) + '%',\n\n      rank: i + 1, \n    }\n  }\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
