    {
      "parameters": {
        "jsCode": "const token  = '__REDACTED_ACCESS_TOKEN__';\nconst userId = '__REDACTED_ID__';\n\n// 期間をUNIX秒に\nconst since = Math.floor(new Date('2025-09-01T00:00:00Z').getTime() / 1000);\n\nlet nextUrl =\n  `https://graph.threads.net/v1.0/${userId}/threads` +\n  `?fields=id,text,timestamp,permalink` +\n  `&since=${since}` +\n  `&access_token=${token}`;\n\nconst all = [];\nwhile (nextUrl) {\n  const res = await this.helpers.httpRequest({ method: 'GET', url: nextUrl, json: true });\n  all.push(...(res.data || []));\n  nextUrl = res.paging?.next || null;\n}\nreturn all.map(p => ({ json: p }));"
      },
